# Go Chicken - Environment Configuration TEMPLATE
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to Git!

# Environment
ENVIRONMENT=development
DEMO_MODE=true

# Application Secrets
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# PostgreSQL (asyncpg) — update with your actual credentials
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD_HERE@localhost:5432/go_chicken

# Supabase Keys (For direct REST/Storage if needed by backend)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI Configuration
AI_PROVIDER=ollama  # 'ollama' or 'groq'
GROQ_API_KEY=gsk_your_groq_api_key_here

# Ollama AI (local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=mistral
OLLAMA_CONFIDENCE_THRESHOLD=0.6

# WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=gochicken123
WHATSAPP_API_TOKEN=your_meta_graph_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# n8n Orchestrator (if applicable)
N8N_WEBHOOK_SECRET=your_n8n_secret

# Pricing (₹ per kg)
PRICE_LIVE_BIRD=180.00
PRICE_DRESSED=250.00
PRICE_SKINLESS=320.00
