# Go Chicken - Environment Configuration TEMPLATE
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to Git!

# Application
APP_NAME=Go Chicken API
APP_VERSION=0.1.0
DEBUG=True

# PostgreSQL (asyncpg) — update with your actual credentials
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD_HERE@localhost:5435/go_chicken

# IoT Thresholds
TEMPERATURE_ALERT_THRESHOLD=35.0

# Ollama AI (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=mistral

# WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=gochicken123
WHATSAPP_API_TOKEN=your_meta_graph_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Ollama Confidence Threshold
OLLAMA_CONFIDENCE_THRESHOLD=0.6

# Pricing (₹ per kg)
PRICE_LIVE_BIRD=180.00
PRICE_DRESSED=250.00
PRICE_SKINLESS=320.00
